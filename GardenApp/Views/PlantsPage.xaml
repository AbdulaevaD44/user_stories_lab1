<Page x:Class="GardenApp.Views.PlantsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои растения">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🌱 Мои растения" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

        <!-- Блок напоминаний о поливе (история #1) -->
        <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="💧 Напоминания о поливе" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <ListBox x:Name="WateringRemindersList" Height="80" Background="Transparent" BorderThickness="0"/>
                <Button x:Name="RefreshWateringBtn" Content="🔄 Обновить напоминания" Click="RefreshWateringBtn_Click" Margin="0,10,0,0" HorizontalAlignment="Left" Background="#4CAF50" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Список растений (история #2) -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="🌿 Мои грядки" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <ListView x:Name="PlantsList" Height="200">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название" Width="120" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Местоположение" Width="150" DisplayMemberBinding="{Binding Location}"/>
                        <GridViewColumn Header="Посажено" Width="100" DisplayMemberBinding="{Binding PlantingDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                        <GridViewColumn Header="Последний полив" Width="100" DisplayMemberBinding="{Binding LastWateredDate, StringFormat={}{0:dd.MM}}"/>
                        <GridViewColumn Header="Полив каждые (дн.)" Width="100" DisplayMemberBinding="{Binding WateringIntervalDays}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            
            <!-- Кнопка для редактирования местоположения (история #2) -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Новое расположение:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="NewLocationBox" Width="150" Margin="0,0,10,0"/>
                <Button x:Name="UpdateLocationBtn" Content="✏️ Обновить местоположение" Click="UpdateLocationBtn_Click" Background="#FF9800" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>