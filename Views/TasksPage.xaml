<Page x:Class="GardenApp.Views.TasksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Задачи на неделю">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✅ Список дел в саду" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

        <!-- Список задач -->
        <ListView x:Name="TasksList" Grid.Row="1" Height="250">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Выполнено?" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsCompleted}" Tag="{Binding}" Unchecked="TaskStatusChanged" Checked="TaskStatusChanged"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Задача" Width="250" DisplayMemberBinding="{Binding Description}"/>
                    <GridViewColumn Header="Срок" Width="100" DisplayMemberBinding="{Binding DueDate, StringFormat={}{0:dd.MM}}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Форма добавления новой задачи -->
        <Border Grid.Row="2" Background="#E3F2FD" CornerRadius="10" Padding="15" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="➕ Новая задача" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Описание:" VerticalAlignment="Center" Width="80"/>
                    <TextBox x:Name="NewTaskDesc" Width="250" Margin="0,0,10,0"/>
                    <TextBlock Text="Срок:" VerticalAlignment="Center" Width="40"/>
                    <DatePicker x:Name="NewTaskDate" Width="120"/>
                </StackPanel>
                <Button x:Name="AddTaskBtn" Content="➕ Добавить задачу" Click="AddTaskBtn_Click" Width="150" HorizontalAlignment="Left" Background="#4CAF50" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <Border Grid.Row="3" Background="#C8E6C9" CornerRadius="10" Padding="10" Margin="0,20,0,0">
            <TextBlock x:Name="StatsText" Text="Статистика: " FontWeight="Bold"/>
        </Border>
    </Grid>
</Page>